## .gitignore

```gitignore
# Environment variables — never commit real credentials
.env
.env.local
.env.*.local

# SQLite and database files
*.db
*.sqlite
*.sqlite3

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# Virtual environments
venv/
.venv/
env/
ENV/

# macOS system files
.DS_Store
.AppleDouble
.LSOverride

# Editor files
.vscode/
.idea/
*.swp
*.swo

# Credentials catch-all
*credentials*
*secrets*
*secret_key*
service_account*.json

# Logs
*.log
logs/

# Build artifacts
dist/
build/
*.egg-info/
.eggs/

# pytest
.pytest_cache/
.coverage
htmlcov/

# DbSchema temp files
*.dbs.bak
